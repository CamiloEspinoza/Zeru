<!DOCTYPE html>
<html>
<head>
<meta charset="ISO-8859-1">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: Arial, Helvetica, sans-serif; font-size: 11px; color: #333; padding: 15mm; width: 216mm; }

  .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; border-bottom: 2px solid #333; padding-bottom: 10px; }
  .company-info { flex: 1; }
  .company-info h1 { font-size: 14px; margin-bottom: 2px; }
  .company-info p { font-size: 10px; line-height: 1.4; }
  .logo { max-width: 120px; max-height: 60px; margin-right: 10px; }

  .rut-box { border: 3px solid #E4002B; padding: 8px 15px; text-align: center; min-width: 180px; }
  .rut-box p { color: #E4002B; font-weight: bold; }
  .rut-box .rut { font-size: 14px; }
  .rut-box .doc-type { font-size: 12px; text-transform: uppercase; }
  .rut-box .folio { font-size: 16px; }

  .resolution { text-align: center; font-size: 9px; color: #666; margin-top: 3px; }

  .receptor { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; margin: 10px 0; padding: 8px; background: #f9f9f9; border: 1px solid #ddd; }
  .receptor .label { font-size: 9px; color: #666; }
  .receptor .value { font-size: 11px; font-weight: 500; }
  .receptor .full-width { grid-column: 1 / -1; }

  .meta-row { display: flex; gap: 20px; margin: 8px 0; font-size: 10px; }
  .meta-row .item { display: flex; gap: 5px; }
  .meta-row .label { color: #666; }

  table.items { width: 100%; border-collapse: collapse; margin: 10px 0; }
  table.items th { background: #333; color: white; padding: 5px 8px; text-align: left; font-size: 10px; font-weight: 600; }
  table.items td { padding: 4px 8px; border-bottom: 1px solid #eee; font-size: 10px; }
  table.items tr:nth-child(even) { background: #fafafa; }
  table.items .right { text-align: right; }
  table.items .center { text-align: center; }

  .totals { display: flex; justify-content: flex-end; margin: 10px 0; }
  .totals table { border-collapse: collapse; }
  .totals td { padding: 3px 12px; font-size: 11px; }
  .totals .label { text-align: right; color: #666; }
  .totals .value { text-align: right; font-weight: 600; }
  .totals .total-row td { border-top: 2px solid #333; font-size: 13px; }

  .references { margin: 10px 0; padding: 8px; background: #fff8e1; border: 1px solid #ffe082; font-size: 10px; }
  .references h3 { font-size: 11px; margin-bottom: 5px; }

  .footer { margin-top: 15px; border-top: 1px solid #ddd; padding-top: 10px; }
  .timbre-section { display: flex; align-items: flex-start; gap: 15px; }
  .timbre-img { width: 200px; }
  .timbre-text { font-size: 8px; color: #666; }

  .acuse-recibo { margin-top: 15px; border: 1px solid #999; padding: 8px; font-size: 9px; }
  .acuse-recibo h4 { margin-bottom: 5px; }
  .acuse-recibo .signature-line { border-bottom: 1px solid #999; width: 200px; margin-top: 20px; }

  .format-number { font-variant-numeric: tabular-nums; }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div style="display: flex; align-items: flex-start;">
    {{#if branding.logoUrl}}
    <img src="{{branding.logoUrl}}" class="logo" />
    {{/if}}
    <div class="company-info">
      <h1>{{emisor.razonSocial}}</h1>
      <p>{{emisor.giro}}</p>
      <p>{{emisor.direccion}}, {{emisor.comuna}}</p>
    </div>
  </div>
  <div>
    <div class="rut-box">
      <p class="rut">R.U.T.: {{emisor.rut}}</p>
      <p class="doc-type">{{tipoDteNombre}}</p>
      <p class="folio">N° {{folio}}</p>
    </div>
    <p class="resolution">S.I.I. — {{emisor.ciudad}}</p>
  </div>
</div>

<!-- RECEPTOR -->
<div class="receptor">
  <div>
    <span class="label">RUT</span><br>
    <span class="value">{{receptor.rut}}</span>
  </div>
  <div>
    <span class="label">Fecha Emision</span><br>
    <span class="value">{{fechaEmision}}</span>
  </div>
  <div class="full-width">
    <span class="label">Senor(es)</span><br>
    <span class="value">{{receptor.razonSocial}}</span>
  </div>
  <div>
    <span class="label">Giro</span><br>
    <span class="value">{{receptor.giro}}</span>
  </div>
  <div>
    <span class="label">Direccion</span><br>
    <span class="value">{{receptor.direccion}}{{#if receptor.comuna}}, {{receptor.comuna}}{{/if}}</span>
  </div>
</div>

<!-- META ROW -->
<div class="meta-row">
  {{#if formaPagoNombre}}
  <div class="item"><span class="label">Forma de Pago:</span> {{formaPagoNombre}}</div>
  {{/if}}
  {{#if fechaVenc}}
  <div class="item"><span class="label">Fecha Venc.:</span> {{fechaVenc}}</div>
  {{/if}}
</div>

<!-- ITEMS TABLE -->
<table class="items">
  <thead>
    <tr>
      <th style="width: 40px;">#</th>
      <th>Descripcion</th>
      <th class="center" style="width: 60px;">Cant.</th>
      <th class="center" style="width: 50px;">Und.</th>
      <th class="right" style="width: 90px;">P. Unit.</th>
      <th class="right" style="width: 80px;">Desc.</th>
      <th class="right" style="width: 90px;">Total</th>
    </tr>
  </thead>
  <tbody>
    {{#each items}}
    <tr>
      <td>{{lineNumber}}</td>
      <td>{{itemName}}{{#if description}}<br><span style="font-size:9px;color:#666;">{{description}}</span>{{/if}}</td>
      <td class="center format-number">{{formatNumber quantity}}</td>
      <td class="center">{{unit}}</td>
      <td class="right format-number">${{formatNumber unitPrice}}</td>
      <td class="right format-number">{{#if discount}}-${{formatNumber discount}}{{/if}}</td>
      <td class="right format-number">${{formatNumber montoItem}}</td>
    </tr>
    {{/each}}
  </tbody>
</table>

<!-- TOTALS -->
<div class="totals">
  <table>
    {{#if montoNeto}}
    <tr><td class="label">Monto Neto:</td><td class="value format-number">${{formatNumber montoNeto}}</td></tr>
    {{/if}}
    {{#if montoExento}}
    <tr><td class="label">Monto Exento:</td><td class="value format-number">${{formatNumber montoExento}}</td></tr>
    {{/if}}
    {{#if iva}}
    <tr><td class="label">IVA ({{tasaIva}}%):</td><td class="value format-number">${{formatNumber iva}}</td></tr>
    {{/if}}
    <tr class="total-row"><td class="label">TOTAL:</td><td class="value format-number">${{formatNumber montoTotal}}</td></tr>
  </table>
</div>

<!-- REFERENCES (for NC/ND) -->
{{#if references.length}}
<div class="references">
  <h3>Documento de Referencia</h3>
  {{#each references}}
  <p>Tipo: {{tipoDocNombre}} | Folio: {{folioRef}} | Fecha: {{fechaRef}} {{#if razonRef}}| Razon: {{razonRef}}{{/if}}</p>
  {{/each}}
</div>
{{/if}}

<!-- FOOTER: TIMBRE + ACUSE -->
<div class="footer">
  <div class="timbre-section">
    {{#if pdf417Base64}}
    <img src="{{pdf417Base64}}" class="timbre-img" />
    {{/if}}
    <div class="timbre-text">
      <p><strong>Timbre Electronico SII</strong></p>
      <p>Res. Ex. SII N° {{resolutionNum}} del {{resolutionDate}}</p>
      <p>Verifique documento: www.sii.cl/verificaDTE</p>
    </div>
  </div>

  {{#unless isBoleta}}
  <div class="acuse-recibo">
    <h4>Acuse de Recibo (Ley 19.983)</h4>
    <p>Nombre: __________________________ RUT: __________________</p>
    <p>Fecha: _______________ Recinto: __________________________</p>
    <p style="font-size:8px;margin-top:5px;">El acuse de recibo que se declara en este acto, de acuerdo a lo dispuesto en la letra b) del Art. 4, y la letra c) del Art. 5 de la Ley 19.983, acredita que la entrega de mercaderias o servicio(s) prestado(s) ha(n) sido recibido(s).</p>
    <div class="signature-line"></div>
    <p style="font-size:8px;">Firma</p>
  </div>
  {{/unless}}
</div>

</body>
</html>
