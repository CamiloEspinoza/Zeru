generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "citolab_fm", "mod_lab"]
}

enum PaymentTerms {
  IMMEDIATE
  NET_15
  NET_30
  NET_45
  NET_60
  NET_90
  CUSTOM

  @@schema("public")
}

enum BankAccountType {
  CHECKING
  SAVINGS
  VISTA
  OTHER

  @@schema("public")
}

enum LabOriginCategory {
  CONSULTA
  CENTRO_MEDICO
  CLINICA_HOSPITAL
  LABORATORIO
  OTRO

  @@schema("public")
}

enum SampleReceptionMode {
  PRESENCIAL
  COURIER
  AMBAS

  @@schema("public")
}

enum ReportDeliveryMethod {
  WEB
  IMPRESO
  FTP
  EMAIL

  @@schema("public")
}

enum BillingAgreementStatus {
  ACTIVE
  EXPIRED
  DRAFT

  @@schema("public")
}

enum BillingModality {
  MONTHLY_SETTLEMENT
  FONASA_VOUCHER
  ISAPRE_VOUCHER
  CASH
  CHECK
  BANK_TRANSFER
  OTHER

  @@schema("public")
}

// ─── Projects & Tasks Enums ─────────────────────────────

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED

  @@map("project_status")
  @@schema("public")
}

enum ProjectVisibility {
  PUBLIC
  PRIVATE

  @@map("project_visibility")
  @@schema("public")
}

enum ProjectMemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER

  @@map("project_member_role")
  @@schema("public")
}

enum TaskPriority {
  URGENT
  HIGH
  MEDIUM
  LOW
  NONE

  @@map("task_priority")
  @@schema("public")
}

enum TaskViewType {
  BOARD
  LIST
  CALENDAR
  TIMELINE

  @@map("task_view_type")
  @@schema("public")
}

// ─── Core ────────────────────────────────────────────────

model Tenant {
  id                    String    @id @default(uuid())
  name                  String
  slug                  String    @unique
  rut                   String?
  address               String?
  phone                 String?
  isActive              Boolean   @default(true)
  onboardingCompletedAt DateTime?
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  memberships         UserTenant[]
  aiUsageLogs         AiUsageLog[]
  aiConfig            AiProviderConfig?
  geminiConfig        GeminiConfig?
  storageConfig       StorageConfig?
  emailConfig         EmailConfig?
  branding            TenantBranding?
  conversations       Conversation[]
  accounts            Account[]
  journalEntries      JournalEntry[]
  fiscalPeriods       FiscalPeriod[]
  documents           Document[]
  accountingSteps     AccountingProcessStep[]
  memories            Memory[]
  agentSkills         AgentSkill[]
  apiKeys             ApiKey[]
  linkedInConnection  LinkedInConnection?
  linkedInPosts       LinkedInPost[]
  linkedInAgentConfig LinkedInAgentConfig?
  orgProjects         OrgProject[]
  departments         Department[]
  personProfiles      PersonProfile[]
  orgSuggestions      OrgSuggestion[]
  channels            Channel[]
  notifications       Notification[]
  roles               Role[]
  fmSyncRecords       FmSyncRecord[]
  legalEntities       LegalEntity[]
  labOrigins          LabOrigin[]
  billingAgreements   BillingAgreement[]
  billingConcepts     BillingConcept[]
  projects            Project[]
  dteConfig           DteConfig?
  dteCertificates     DteCertificate[]
  dteFolios           DteFolio[]
  dtes                Dte[]
  dteRcofs            DteRcof[]
  dteAccountMappings  DteAccountMapping[]

  @@map("tenants")
  @@schema("public")
}

enum UserType {
  HUMAN
  SERVICE

  @@map("user_type")
  @@schema("public")
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  password   String?
  firstName  String
  lastName   String
  avatarUrl  String?
  isActive   Boolean   @default(true)
  superAdmin Boolean   @default(false)
  type       UserType  @default(HUMAN)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  memberships             UserTenant[]
  conversations           Conversation[]
  documents               Document[]
  stepCompletions         AccountingStepCompletion[]
  memories                Memory[]
  journalEntriesCreated   JournalEntry[]
  apiKeys                 ApiKey[]
  orgProjectsCreated      OrgProject[]               @relation("OrgProjectsCreated")
  aiUsageLogs             AiUsageLog[]
  channelsCreated         Channel[]                  @relation("ChannelCreator")
  channelMemberships      ChannelMember[]
  chatMessages            ChatMessage[]              @relation("ChatMessageAuthor")
  chatReactions           ChatReaction[]             @relation("ChatReactionUser")
  chatMentionsOf          ChatMention[]              @relation("ChatMentionTarget")
  notifications           Notification[]             @relation("NotificationRecipient")
  notificationPreferences NotificationPreference[]   @relation("NotificationPref")
  personProfiles          PersonProfile[]
  projectsCreated         Project[]                  @relation("ProjectsCreated")
  projectMemberships      ProjectMember[]            @relation("ProjectMemberships")
  tasksCreated            Task[]                     @relation("TasksCreated")
  taskAssignments         TaskAssignee[]             @relation("TaskAssignments")
  taskSubscriptions       TaskSubscriber[]           @relation("TaskSubscriptions")
  taskComments            TaskComment[]              @relation("TaskComments")
  taskCommentReactions    TaskCommentReaction[]      @relation("TaskCommentReactions")
  taskActivities          TaskActivity[]             @relation("TaskActivities")
  taskAttachments         TaskAttachment[]           @relation("TaskAttachments")
  taskViewsCreated        TaskView[]                 @relation("TaskViewsCreated")
  taskPropertyPersonValues TaskPropertyValue[]       @relation("TaskPropertyPersonValues")
  dtesCreated              Dte[]                     @relation("DteCreatedBy")
  dtesDecided              Dte[]                     @relation("DteDecidedBy")

  @@map("users")
  @@schema("public")
}

/// Membresía: un usuario puede pertenecer a múltiples tenants con roles distintos
model UserTenant {
  id        String    @id @default(uuid())
  role      UserRole  @default(OWNER)
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  roleId  String?
  roleRef Role?   @relation(fields: [roleId], references: [id])

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("user_tenants")
  @@schema("public")
}

enum UserRole {
  /// Rol inicial: acceso completo. Roles granulares se añadirán aquí en el futuro.
  OWNER
  ADMIN
  ACCOUNTANT
  VIEWER

  @@schema("public")
}

// ─── RBAC ────────────────────────────────────────────────

enum AccessLevel {
  NONE
  VIEW
  EDIT
  MANAGE

  @@schema("public")
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  isSystem    Boolean  @default(false)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  moduleAccess RoleModuleAccess[]
  overrides    RolePermissionOverride[]
  members      UserTenant[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("roles")
  @@schema("public")
}

model RoleModuleAccess {
  id          String      @id @default(uuid())
  roleId      String
  role        Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  moduleKey   String
  accessLevel AccessLevel @default(NONE)

  @@unique([roleId, moduleKey])
  @@index([roleId])
  @@map("role_module_access")
  @@schema("public")
}

model RolePermissionOverride {
  id         String  @id @default(uuid())
  roleId     String
  role       Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission String
  granted    Boolean

  @@unique([roleId, permission])
  @@index([roleId])
  @@map("role_permission_overrides")
  @@schema("public")
}

// ─── AI ──────────────────────────────────────────────────

enum AiProvider {
  OPENAI

  @@map("ai_provider")
  @@schema("public")
}

/// Registro detallado de cada interacción con modelos de IA para análisis de costos
model AiUsageLog {
  id              String   @id @default(uuid())
  provider        String // OPENAI, GEMINI, etc.
  model           String // gpt-5.4, text-embedding-3-small, etc.
  feature         String // chat, embedding, title-generation, image-generation
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  totalTokens     Int      @default(0)
  cachedTokens    Int      @default(0)
  /// Whether compaction was triggered during this interaction
  compacted       Boolean  @default(false)
  costUsd         Decimal  @default(0)
  costOverrideUsd Decimal?
  units           Decimal?
  pricingUnit     String?
  createdAt       DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([conversationId])
  @@index([tenantId, userId, createdAt])
  @@map("ai_usage_logs")
  @@schema("public")
}

model AiModelPricing {
  id                   String    @id @default(uuid())
  provider             String
  model                String
  contextTier          String    @default("DEFAULT")
  pricingUnit          String // PER_1M_TOKENS, PER_1K_CHARS, PER_HOUR, PER_MINUTE, PER_IMAGE, PER_GENERATION
  inputPrice           Decimal   @default(0)
  outputPrice          Decimal   @default(0)
  cachedPrice          Decimal   @default(0)
  longContextThreshold Int?
  description          String?
  validFrom            DateTime
  validTo              DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([provider, model, contextTier, validFrom])
  @@index([provider, model])
  @@map("ai_model_pricing")
  @@schema("public")
}

/// Configuracion de proveedor de IA por tenant
model AiProviderConfig {
  id              String     @id @default(uuid())
  provider        AiProvider @default(OPENAI)
  encryptedApiKey String
  model           String     @default("gpt-5.4")
  reasoningEffort String     @default("medium")
  isActive        Boolean    @default(true)
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ai_provider_configs")
  @@schema("public")
}

/// API key de Google Gemini por tenant (para generación de imágenes)
model GeminiConfig {
  id              String    @id @default(uuid())
  encryptedApiKey String
  isActive        Boolean   @default(true)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("gemini_configs")
  @@schema("public")
}

/// Configuracion de almacenamiento S3 por tenant
model StorageConfig {
  id                   String    @id @default(uuid())
  region               String    @default("us-east-1")
  encryptedAccessKeyId String
  encryptedSecretKey   String
  encryptedBucket      String
  isActive             Boolean   @default(true)
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("storage_configs")
  @@schema("public")
}

/// Configuración de AWS SES para envío de correos por tenant
model EmailConfig {
  id                   String    @id @default(uuid())
  region               String    @default("us-east-1")
  encryptedAccessKeyId String
  encryptedSecretKey   String
  encryptedFromEmail   String
  isActive             Boolean   @default(true)
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("email_configs")
  @@schema("public")
}

/// Sesion de chat entre un usuario y el asistente IA
model Conversation {
  id                 String    @id @default(uuid())
  title              String    @default("Nueva conversación")
  /// GENERAL | LINKEDIN
  agentType          String    @default("GENERAL")
  lastResponseId     String?
  /// The previous_response_id that was used when the last response was generated (used for manual context reconstruction)
  parentResponseId   String?
  /// Full response.output array from the last OpenAI response (needed for manual context on tool answer)
  lastResponseOutput Json?
  pendingToolOutputs Json?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  messages       Message[]
  documents      Document[]
  journalEntries JournalEntry[]
  linkedInPosts  LinkedInPost[]
  aiUsageLogs    AiUsageLog[]

  @@index([userId])
  @@index([tenantId])
  @@index([tenantId, agentType])
  @@map("conversations")
  @@schema("public")
}

enum MessageRole {
  user
  assistant
  tool
  question

  @@map("message_role")
  @@schema("public")
}

/// Mensaje individual dentro de una conversacion
model Message {
  id         String      @id @default(uuid())
  role       MessageRole
  content    Json
  toolName   String?
  toolArgs   Json?
  toolResult Json?
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())

  tenantId       String?
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([tenantId])
  @@map("messages")
  @@schema("public")
}

// ─── Memory ──────────────────────────────────────────────

enum MemoryCategory {
  PREFERENCE
  FACT
  PROCEDURE
  DECISION
  CONTEXT

  @@map("memory_category")
  @@schema("public")
}

/// Memoria persistente del asistente por tenant/usuario
model Memory {
  id         String                       @id @default(uuid())
  content    String
  category   MemoryCategory               @default(CONTEXT)
  /// Relevancia 1-10; el modelo asigna la importancia al guardar
  importance Int                          @default(5)
  /// Embedding pgvector(1536) para búsqueda semántica — gestionado via raw SQL
  embedding  Unsupported("vector(1536)")?
  isActive   Boolean                      @default(true)
  deletedAt  DateTime?
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// null = memoria de la organización; userId presente = memoria del usuario
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Documento de origen (si la memoria fue extraída de un documento)
  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId, tenantId])
  @@index([documentId])
  @@map("memories")
  @@schema("public")
}

// ─── Accounting ──────────────────────────────────────────

model Account {
  id          String              @id @default(uuid())
  code        String
  name        String
  type        AccountType
  /// Sección IFRS IAS 1 (solo en cuentas REVENUE/EXPENSE). Se hereda del ancestro raíz.
  ifrsSection AccountIFRSSection?
  isActive    Boolean             @default(true)
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  parentId String?
  parent   Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children Account[] @relation("AccountHierarchy")

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  journalEntryLines JournalEntryLine[]

  @@unique([code, tenantId])
  @@index([tenantId])
  @@map("accounts")
  @@schema("public")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE

  @@schema("public")
}

/// Clasificación funcional IFRS (IAS 1) para el Estado de Resultados.
/// Se asigna a cuentas de tipo REVENUE o EXPENSE para estructurar
/// la presentación por función: ingresos, costo de ventas, gastos operativos,
/// resultado financiero e impuesto.
enum AccountIFRSSection {
  REVENUE
  OTHER_INCOME
  COST_OF_SALES
  OPERATING_EXPENSE
  FINANCE_INCOME
  FINANCE_COST
  TAX_EXPENSE

  @@map("account_ifrs_section")
  @@schema("public")
}

/// Origen del asiento: asistente IA o manual (formulario)
enum JournalEntrySource {
  ASSISTANT
  MANUAL

  @@map("journal_entry_source")
  @@schema("public")
}

model JournalEntry {
  id          String             @id @default(uuid())
  number      Int
  date        DateTime
  description String
  status      JournalEntryStatus @default(DRAFT)
  deletedAt   DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  /// Usuario que creó el asiento (manual o quien confirmó en el asistente)
  createdById    String?
  createdBy      User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)
  /// Origen: asistente o manual
  createdVia     JournalEntrySource?
  /// Conversación del asistente donde se creó (solo si createdVia = ASSISTANT)
  conversationId String?
  conversation   Conversation?       @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  fiscalPeriodId String
  fiscalPeriod   FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  lines     JournalEntryLine[]
  documents DocumentJournalEntry[]
  dte       Dte?

  @@unique([number, tenantId])
  @@index([tenantId])
  @@index([date])
  @@index([createdById])
  @@index([conversationId])
  @@map("journal_entries")
  @@schema("public")
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOIDED

  @@schema("public")
}

model JournalEntryLine {
  id          String    @id @default(uuid())
  debit       Decimal   @default(0) @db.Decimal(18, 2)
  credit      Decimal   @default(0) @db.Decimal(18, 2)
  description String?
  deletedAt   DateTime?

  tenantId       String?
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  accountId String
  account   Account @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([tenantId])
  @@map("journal_entry_lines")
  @@schema("public")
}

model FiscalPeriod {
  id        String             @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  status    FiscalPeriodStatus @default(OPEN)
  deletedAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  journalEntries  JournalEntry[]
  stepCompletions AccountingStepCompletion[]

  @@index([tenantId])
  @@map("fiscal_periods")
  @@schema("public")
}

enum FiscalPeriodStatus {
  OPEN
  CLOSED

  @@schema("public")
}

/// Paso del proceso contable configurable por organización
model AccountingProcessStep {
  id          String    @id @default(uuid())
  name        String
  description String?
  order       Int
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  completions AccountingStepCompletion[]

  @@index([tenantId])
  @@map("accounting_process_steps")
  @@schema("public")
}

/// Estado de completitud de un paso de proceso para un período fiscal
model AccountingStepCompletion {
  id          String     @id @default(uuid())
  status      StepStatus @default(PENDING)
  completedAt DateTime?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenantId String?
  stepId   String
  step     AccountingProcessStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  fiscalPeriodId String
  fiscalPeriod   FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)

  completedById String?
  completedBy   User?   @relation(fields: [completedById], references: [id], onDelete: SetNull)

  @@unique([stepId, fiscalPeriodId])
  @@index([fiscalPeriodId])
  @@index([tenantId])
  @@map("accounting_step_completions")
  @@schema("public")
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED

  @@schema("public")
}

// ─── Documents ────────────────────────────────────────────

enum DocumentCategory {
  FACTURA
  BOLETA
  NOTA_CREDITO
  NOTA_DEBITO
  CONTRATO
  ESTATUTOS
  DECLARACION
  COMPROBANTE
  REMUNERACION
  OTRO

  @@schema("public")
}

/// Documento adjunto: almacenado en S3, asociado a conversacion y asientos
model Document {
  id        String           @id @default(uuid())
  name      String
  s3Key     String
  mimeType  String
  sizeBytes Int
  category  DocumentCategory @default(OTRO)
  tags      String[]
  deletedAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  journalEntries DocumentJournalEntry[]
  memories       Memory[]

  @@index([tenantId])
  @@index([conversationId])
  @@map("documents")
  @@schema("public")
}

/// Relacion muchos-a-muchos entre documentos y asientos contables
model DocumentJournalEntry {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  tenantId   String?
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@unique([documentId, journalEntryId])
  @@index([tenantId])
  @@map("document_journal_entries")
  @@schema("public")
}

// ─── Agent Skills ─────────────────────────────────────────

/// Skill instalado por un tenant para extender las capacidades del agente de IA
model AgentSkill {
  id          String    @id @default(uuid())
  name        String
  description String?
  repoUrl     String
  /// Contenido del SKILL.md (body sin frontmatter)
  content     String
  version     String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  files AgentSkillFile[]

  @@unique([tenantId, repoUrl])
  @@index([tenantId])
  @@map("agent_skills")
  @@schema("public")
}

/// Archivo de referencia o script perteneciente a un AgentSkill
model AgentSkillFile {
  id        String    @id @default(uuid())
  /// Ruta relativa dentro del skill, ej: "references/api_docs.md"
  path      String
  content   String
  deletedAt DateTime?

  tenantId String?
  skillId  String
  skill    AgentSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, path])
  @@index([skillId])
  @@index([tenantId])
  @@map("agent_skill_files")
  @@schema("public")
}

model ApiKey {
  id          String    @id @default(uuid())
  name        String
  keyPrefix   String
  keyHash     String    @unique
  scopes      String[]
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  lastUsedAt  DateTime?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([keyHash])
  @@map("api_keys")
  @@schema("public")
}

/// Código de login passwordless (6 dígitos enviados por email)
model LoginCode {
  id        String    @id @default(uuid())
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int       @default(0)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@map("login_codes")
  @@schema("public")
}

/// Registro de emails en lista de espera
model WaitlistEntry {
  id        String    @id @default(uuid())
  email     String    @unique
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@map("waitlist_entries")
  @@schema("public")
}

model FeatureRequest {
  id        String   @id @default(uuid())
  text      String
  email     String?
  ip        String?
  createdAt DateTime @default(now())

  @@map("feature_requests")
  @@schema("public")
}

// ─── LinkedIn ─────────────────────────────────────────────

/// Conexión OAuth de LinkedIn por tenant (1 por tenant)
model LinkedInConnection {
  id                    String    @id @default(uuid())
  /// Access token encriptado con ENCRYPTION_KEY
  accessToken           String
  /// Refresh token encriptado (LinkedIn emite refresh tokens de larga duración)
  refreshToken          String?
  expiresAt             DateTime
  /// urn:li:person:xxx
  personUrn             String
  profileName           String?
  profileImage          String?
  /// Token de la app Community Management (r_organization_followers) — encriptado
  communityAccessToken  String?
  communityRefreshToken String?
  communityExpiresAt    DateTime?
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("linkedin_connections")
  @@schema("public")
}

/// Post de LinkedIn creado o programado por el agente
model LinkedInPost {
  id             String    @id @default(uuid())
  /// Texto del post (commentary)
  content        String
  /// NONE | ARTICLE | IMAGE
  mediaType      String    @default("NONE")
  /// URL de S3 para imágenes, URL externa para artículos
  mediaUrl       String?
  /// S3 key de la imagen generada por Gemini
  imageS3Key     String?
  /// Prompt sugerido/usado para la generación de la imagen
  imagePrompt    String?
  /// DRAFT | PENDING_APPROVAL | SCHEDULED | PUBLISHED | FAILED | CANCELLED
  status         String    @default("DRAFT")
  /// Fecha/hora programada para auto-publicar
  scheduledAt    DateTime?
  /// URN retornado por LinkedIn al publicar (ej: urn:li:share:xxx)
  linkedinPostId String?
  publishedAt    DateTime?
  errorMessage   String?
  /// Pilar de contenido (ej: "thought-leadership", "tips", "case-study")
  contentPillar  String?
  /// PUBLIC | CONNECTIONS
  visibility     String    @default("PUBLIC")
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  versions      LinkedInPostVersion[]
  imageVersions LinkedInImageVersion[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([status, scheduledAt])
  @@map("linkedin_posts")
  @@schema("public")
}

/// Versión del contenido de texto de un post (para historial de regeneraciones)
model LinkedInPostVersion {
  id            String       @id @default(uuid())
  postId        String
  post          LinkedInPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// Contenido del post en esta versión
  content       String
  /// Número de versión (1, 2, 3...)
  versionNumber Int
  /// Instrucciones de regeneración que produjeron esta versión (null para la versión original)
  instructions  String?
  tenantId      String?
  createdAt     DateTime     @default(now())

  @@index([postId])
  @@index([tenantId])
  @@map("linkedin_post_versions")
  @@schema("public")
}

/// Versión de imagen generada para un post
model LinkedInImageVersion {
  id            String       @id @default(uuid())
  postId        String
  post          LinkedInPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// Prompt usado para generar la imagen
  prompt        String
  /// URL pública de la imagen en S3
  imageUrl      String
  /// S3 key de la imagen
  imageS3Key    String
  /// Número de versión (1, 2, 3...)
  versionNumber Int
  /// Si esta versión es la seleccionada actualmente
  isSelected    Boolean      @default(false)
  tenantId      String?
  createdAt     DateTime     @default(now())

  @@index([postId])
  @@index([tenantId])
  @@map("linkedin_image_versions")
  @@schema("public")
}

/// Configuración del agente de LinkedIn por tenant
model LinkedInAgentConfig {
  id                String    @id @default(uuid())
  /// Si true, los posts se publican directamente sin aprobación
  autoPublish       Boolean   @default(false)
  defaultVisibility String    @default("PUBLIC")
  /// Pilares de contenido configurados: ["thought-leadership", "tips", ...]
  contentPillars    Json?
  /// URN de la organización para People Typeahead API — urn:li:organization:xxx
  organizationUrn   String?
  deletedAt         DateTime?
  /// Idioma preferido para los prompts de generación de imágenes (ej: "es", "en", "pt")
  preferredLanguage String    @default("es")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("linkedin_agent_configs")
  @@schema("public")
}

// ─── Person Profiles ─────────────────────────────────────

enum PersonStatus {
  ACTIVE
  INACTIVE
  VACANT

  @@map("person_status")
  @@schema("public")
}

enum PersonSource {
  MANUAL
  AI_INFERRED
  AI_CONFIRMED
  CSV_IMPORT

  @@map("person_source")
  @@schema("public")
}

/// Departamento organizacional
model Department {
  id          String  @id @default(uuid())
  name        String
  description String?
  color       String?

  parentId String?
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Department[] @relation("DepartmentHierarchy")

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  persons PersonProfile[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("departments")
  @@schema("public")
}

/// Perfil de persona para inteligencia organizacional (participantes de entrevistas)
model PersonProfile {
  id           String      @id @default(uuid())
  name         String
  role         String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  personType   String      @default("INTERNAL") // INTERNAL, EXTERNAL, CONTRACTOR
  company      String? // Empresa externa (solo para externos/contratistas)
  email        String?
  phone        String?
  avatarS3Key  String?
  notes        String?

  // ─── Jerarquia organizacional ───
  reportsToId   String?
  reportsTo     PersonProfile?  @relation("ReportsTo", fields: [reportsToId], references: [id], onDelete: SetNull)
  directReports PersonProfile[] @relation("ReportsTo")

  // ─── Metadata organizacional ───
  employeeCode String?
  startDate    DateTime?
  status       PersonStatus @default(ACTIVE)
  source       PersonSource @default(MANUAL)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  orgSuggestions OrgSuggestion[]

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, reportsToId])
  @@index([tenantId, departmentId])
  @@map("person_profiles")
  @@schema("public")
}

// ─── Org Suggestions ─────────────────────────────────────

enum OrgSuggestionType {
  CREATE_PERSON
  UPDATE_PERSON
  SET_REPORTS_TO
  DELETE_PERSON

  @@map("org_suggestion_type")
  @@schema("public")
}

enum OrgSuggestionStatus {
  PENDING
  APPROVED
  APPROVED_MODIFIED
  REJECTED

  @@map("org_suggestion_status")
  @@schema("public")
}

model OrgSuggestion {
  id              String              @id @default(uuid())
  type            OrgSuggestionType
  status          OrgSuggestionStatus @default(PENDING)
  confidence      Float
  data            Json
  evidence        String?
  evidenceTimeSec Int?
  resolvedBy      String?
  resolvedAt      DateTime?
  rejectReason    String?

  personId String?
  person   PersonProfile? @relation(fields: [personId], references: [id], onDelete: SetNull)

  interviewId String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, personId])
  @@map("org_suggestions")
  @@schema("public")
}

// ─── Org Intelligence ────────────────────────────────────

enum OrgProjectStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED

  @@map("org_project_status")
  @@schema("public")
}

enum TranscriptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED

  @@map("transcription_status")
  @@schema("public")
}

enum TranscriptionProvider {
  DEEPGRAM
  OPENAI

  @@map("transcription_provider")
  @@schema("public")
}

enum OrgEntityType {
  ORGANIZATION
  DEPARTMENT
  ROLE
  PROCESS
  ACTIVITY
  SYSTEM
  DOCUMENT_TYPE
  PROBLEM
  IMPROVEMENT

  @@map("org_entity_type")
  @@schema("public")
}

enum OrgRelationType {
  BELONGS_TO
  EXECUTES
  OWNS
  CONTAINS
  DEPENDS_ON
  USES
  PRECEDES
  FOLLOWS
  TRIGGERS
  INPUTS
  OUTPUTS

  @@map("org_relation_type")
  @@schema("public")
}

enum ProblemSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW

  @@map("problem_severity")
  @@schema("public")
}

enum ConflictType {
  FACTUAL
  PERSPECTIVE
  SCOPE

  @@map("conflict_type")
  @@schema("public")
}

enum ConflictResolution {
  PENDING
  RESOLVED_VERIFIED
  RESOLVED_BOTH_VALID
  RESOLVED_MERGED
  DISMISSED

  @@map("conflict_resolution")
  @@schema("public")
}

/// Proyecto de inteligencia organizacional
model OrgProject {
  id          String           @id @default(uuid())
  name        String
  description String?
  status      OrgProjectStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  config      Json?
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("OrgProjectsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  interviews      Interview[]
  orgEntities     OrgEntity[]
  orgRelations    OrgRelation[]
  problems        Problem[]
  improvements    Improvement[]
  factualClaims   FactualClaim[]
  conflictRecords ConflictRecord[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("org_projects")
  @@schema("public")
}

/// Entrevista de diagnóstico organizacional
model Interview {
  id                    String                 @id @default(uuid())
  title                 String?
  audioS3Key            String?
  audioMimeType         String?
  audioDurationMs       Int?
  transcriptionText     String?
  transcriptionJson     Json?
  transcriptionStatus   TranscriptionStatus    @default(PENDING)
  transcriptionProvider TranscriptionProvider?
  interviewDate         DateTime?
  extractionResult      Json?
  processingStatus      String                 @default("PENDING")
  processingError       String?
  processingLog         Json?
  objective             String?
  generatedIntro        String?
  generatedQuestions    Json?
  questionsGeneratedAt  DateTime?
  deletedAt             DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  projectId String
  project   OrgProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tenantId String

  speakers    InterviewSpeaker[]
  chunks      InterviewChunk[]
  audioTracks InterviewAudioTrack[]

  @@index([projectId])
  @@index([tenantId])
  @@index([tenantId, processingStatus])
  @@map("interviews")
  @@schema("public")
}

/// Pista de audio individual dentro de una entrevista multi-audio
model InterviewAudioTrack {
  id           String    @id @default(uuid())
  interviewId  String
  interview    Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  trackOrder   Int
  s3Key        String
  mimeType     String    @default("audio/mpeg")
  durationMs   Int?
  sourceLabel  String?
  originalName String?
  createdAt    DateTime  @default(now())
  tenantId     String

  @@unique([interviewId, trackOrder])
  @@index([interviewId])
  @@map("interview_audio_tracks")
  @@schema("public")
}

/// Hablante identificado en una entrevista
model InterviewSpeaker {
  id            String  @id @default(uuid())
  speakerLabel  String
  name          String?
  role          String?
  department    String?
  isInterviewer Boolean @default(false)

  tenantId    String?
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  personEntityId String?

  chunks InterviewChunk[]

  @@unique([interviewId, speakerLabel])
  @@index([interviewId])
  @@index([tenantId])
  @@map("interview_speakers")
  @@schema("public")
}

/// Fragmento de transcripción con embedding para búsqueda semántica
model InterviewChunk {
  id             String  @id @default(uuid())
  content        String
  contextPrefix  String?
  topicSummary   String?
  startTimeMs    Int?
  endTimeMs      Int?
  chunkOrder     Int
  tokenCount     Int?
  embeddingModel String?

  embedding Unsupported("vector(1536)")?
  tsv       Unsupported("tsvector")?

  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  speakerId String?
  speaker   InterviewSpeaker? @relation(fields: [speakerId], references: [id], onDelete: SetNull)

  parentChunkId String?

  tenantId String

  @@index([interviewId])
  @@index([tenantId])
  @@index([tenantId, interviewId])
  @@map("interview_chunks")
  @@schema("public")
}

/// Entidad del grafo organizacional (departamento, rol, proceso, etc.)
model OrgEntity {
  id                String        @id @default(uuid())
  type              OrgEntityType
  name              String
  description       String?
  metadata          Json?
  status            String        @default("ACTIVE")
  aliases           String[]
  validFrom         DateTime      @default(now())
  validTo           DateTime?
  version           Int           @default(1)
  originalEntityId  String?
  confidence        Float         @default(0.5)
  sourceChunkIds    String[]
  sourceInterviewId String?

  embedding Unsupported("vector(1536)")?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenantId  String
  projectId String
  project   OrgProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  relationsFrom OrgRelation[] @relation("FromEntity")
  relationsTo   OrgRelation[] @relation("ToEntity")
  problemLinks  ProblemLink[]

  @@index([tenantId, projectId, type])
  @@index([tenantId, type, status])
  @@index([tenantId, projectId, type, validTo])
  @@map("org_entities")
  @@schema("public")
}

/// Relación entre dos entidades organizacionales
model OrgRelation {
  id          String          @id @default(uuid())
  type        OrgRelationType
  description String?
  metadata    Json?
  weight      Float           @default(1.0)

  fromEntityId String
  fromEntity   OrgEntity @relation("FromEntity", fields: [fromEntityId], references: [id], onDelete: Cascade)

  toEntityId String
  toEntity   OrgEntity @relation("ToEntity", fields: [toEntityId], references: [id], onDelete: Cascade)

  validFrom         DateTime  @default(now())
  validTo           DateTime?
  confidence        Float     @default(0.5)
  sourceInterviewId String?
  sourceChunkId     String?

  tenantId  String
  projectId String
  project   OrgProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, projectId])
  @@index([fromEntityId])
  @@index([toEntityId])
  @@index([type])
  @@index([tenantId, type, validTo])
  @@map("org_relations")
  @@schema("public")
}

/// Problema detectado en el diagnóstico organizacional
model Problem {
  id                String          @id @default(uuid())
  title             String
  description       String
  severity          ProblemSeverity
  category          String?
  evidence          Json?
  confidence        Float           @default(0.5)
  sourceInterviewId String?
  riceScore         Json?
  deletedAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenantId  String
  projectId String
  project   OrgProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  affectedEntities ProblemLink[]
  improvements     Improvement[]

  @@index([tenantId, projectId])
  @@index([severity])
  @@index([tenantId, projectId, severity])
  @@map("problems")
  @@schema("public")
}

/// Vínculo entre problema y entidad afectada
model ProblemLink {
  id                String  @id @default(uuid())
  impactDescription String?

  tenantId  String?
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  entityId String
  entity   OrgEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([problemId, entityId])
  @@index([problemId])
  @@index([entityId])
  @@index([tenantId])
  @@map("problem_links")
  @@schema("public")
}

/// Mejora propuesta vinculada a un problema
model Improvement {
  id          String    @id @default(uuid())
  title       String
  description String
  type        String?
  effort      String?
  impact      String?
  priority    Int?
  status      String    @default("PROPOSED")
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenantId  String
  projectId String
  project   OrgProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId])
  @@index([problemId])
  @@map("improvements")
  @@schema("public")
}

/// Claim factual extraído de entrevistas (inmutable)
model FactualClaim {
  id                String   @id @default(uuid())
  subject           String
  predicate         String
  object            String
  claimType         String
  confidence        Float    @default(0.5)
  evidence          String?
  sourceInterviewId String?
  sourceChunkId     String?
  createdAt         DateTime @default(now())

  tenantId  String
  projectId String
  project   OrgProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId])
  @@index([subject])
  @@index([tenantId, projectId, subject, predicate])
  @@map("factual_claims")
  @@schema("public")
}

/// Registro de conflicto entre claims o perspectivas
model ConflictRecord {
  id              String             @id @default(uuid())
  type            ConflictType
  description     String
  claimsData      Json
  interviewIds    String[]
  resolution      ConflictResolution @default(PENDING)
  resolutionNotes String?
  resolvedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenantId  String
  projectId String
  project   OrgProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId])
  @@index([tenantId, projectId, resolution])
  @@map("conflict_records")
  @@schema("public")
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  action     String
  changes    Json?
  snapshot   Json?
  actorType  String
  actorId    String?
  source     String
  ipAddress  String?
  userAgent  String?
  socketId   String?
  tenantId   String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, createdAt])
  @@map("audit_logs")
  @@schema("public")
}

// ─── Team Chat ────────────────────────────────────────────

enum ChannelType {
  PUBLIC
  PRIVATE
  DM
  GROUP_DM

  @@schema("public")
}

model Channel {
  id           String      @id @default(uuid())
  name         String?
  slug         String?
  type         ChannelType
  topic        String?
  description  String?
  lastSequence BigInt      @default(0)
  isArchived   Boolean     @default(false)
  deletedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("ChannelCreator", fields: [createdById], references: [id])

  members  ChannelMember[]
  messages ChatMessage[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, type])
  @@map("channels")
  @@schema("public")
}

model ChannelMember {
  id               String   @id @default(uuid())
  role             String   @default("MEMBER")
  lastReadSequence BigInt   @default(0)
  isMuted          Boolean  @default(false)
  joinedAt         DateTime @default(now())

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
  @@map("channel_members")
  @@schema("public")
}

model ChatMessage {
  id        String    @id @default(uuid())
  content   String
  sequence  BigInt
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("ChatMessageAuthor", fields: [authorId], references: [id])

  threadParentId    String?
  threadParent      ChatMessage?  @relation("Thread", fields: [threadParentId], references: [id])
  threadReplies     ChatMessage[] @relation("Thread")
  threadReplyCount  Int           @default(0)
  lastThreadReplyAt DateTime?

  attachments ChatAttachment[]
  reactions   ChatReaction[]
  mentions    ChatMention[]

  @@index([channelId, sequence])
  @@index([channelId, createdAt])
  @@index([threadParentId])
  @@map("chat_messages")
  @@schema("public")
}

model ChatAttachment {
  id        String   @id @default(uuid())
  name      String
  s3Key     String
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())

  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("chat_attachments")
  @@schema("public")
}

model ChatReaction {
  id    String @id @default(uuid())
  emoji String

  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("ChatReactionUser", fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
  @@map("chat_reactions")
  @@schema("public")
}

model ChatMention {
  id String @id @default(uuid())

  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  mentionedUserId String
  mentionedUser   User   @relation("ChatMentionTarget", fields: [mentionedUserId], references: [id])

  @@index([mentionedUserId])
  @@map("chat_mentions")
  @@schema("public")
}

// ─── Notifications ────────────────────────────────────────

model Notification {
  id        String    @id @default(uuid())
  type      String
  title     String
  body      String?
  data      Json
  isRead    Boolean   @default(false)
  readAt    DateTime?
  groupKey  String?
  createdAt DateTime  @default(now())

  recipientId String
  recipient   User   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead, createdAt])
  @@index([recipientId, tenantId, createdAt])
  @@index([groupKey])
  @@map("notifications")
  @@schema("public")
}

model NotificationPreference {
  id             String  @id @default(uuid())
  eventPattern   String
  inApp          Boolean @default(true)
  email          Boolean @default(false)
  push           Boolean @default(false)
  emailFrequency String  @default("INSTANT")

  userId String
  user   User   @relation("NotificationPref", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventPattern])
  @@map("notification_preferences")
  @@schema("public")
}

// ─── Resource Locks ───────────────────────────────────────

model ResourceLock {
  id            String   @id @default(uuid())
  entityType    String
  entityId      String
  fieldName     String
  userId        String
  tenantId      String
  socketId      String
  acquiredAt    DateTime @default(now())
  expiresAt     DateTime
  lastHeartbeat DateTime @default(now())

  @@unique([entityType, entityId, fieldName])
  @@index([socketId])
  @@index([expiresAt])
  @@map("resource_locks")
  @@schema("public")
}

// ─── Legal Entity & Lab Origin ───────────────────────────

model LegalEntity {
  id String @id @default(uuid())

  rut              String
  legalName        String
  tradeName        String?
  businessActivity String?

  isClient   Boolean @default(false)
  isSupplier Boolean @default(false)

  street       String?
  streetNumber String?
  unit         String?
  commune      String?
  city         String?

  email              String?
  phone              String?
  website            String?
  dteExchangeEmail   String?
  isAuthorizedDte    Boolean   @default(false)
  siiLastRefresh     DateTime?

  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  contacts          LegalEntityContact[]
  bankAccounts      LegalEntityBankAccount[]
  labOrigins        LabOrigin[]
  billingAgreements BillingAgreement[]
